---
const authors = [
  {
    name: "Abd Alsalam Hijazi Kelani",
    email: "251132908@st.biruni.edu.tr",
    role: "Computer Engineering",
    initials: "AH",
    color: "#00d4ff",
  },
  {
    name: "Ghaith Almadani",
    email: "251132902@st.biruni.edu.tr",
    role: "Computer Engineering",
    initials: "GA",
    color: "#a855f7",
  },
];
---

<section class="authors-section section">
  <div class="container">
    <p class="section-label">Research Team</p>
    <h2 class="section-title">Authors</h2>
    <div class="divider"></div>
    <div class="authors-grid">
      {authors.map(a => (
        <div class="author-card card">
          <div class="avatar" style={`--c: ${a.color}`}>{a.initials}</div>
          <div>
            <h3 class="author-name">{a.name}</h3>
            <p class="author-role">{a.role}</p>
            <a class="author-email mono" href={`mailto:${a.email}`}>{a.email}</a>
            <p class="author-uni">Biruni University · Istanbul, Turkey</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .authors-section { padding: 4rem 0 5rem; }

  .authors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .author-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--c) 15%, transparent);
    border: 2px solid var(--c);
    color: var(--c);
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  .author-name {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.2rem;
  }

  .author-role {
    font-size: 0.8rem;
    color: var(--cyan);
    margin-bottom: 0.3rem;
  }

  .author-email {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
    display: block;
    margin-bottom: 0.2rem;
    transition: color 0.2s;
  }

  .author-email:hover { color: var(--cyan); }

  .author-uni {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.7;
  }
</style>
