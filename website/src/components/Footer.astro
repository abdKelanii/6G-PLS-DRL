<footer>
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="mono brand">6G / DRL Security</span>
      <p>Mitigating Physical Layer Vulnerabilities in 6G Communications using Deep Reinforcement Learning</p>
      <p class="uni">Biruni University · Dept. of Computer Engineering · Istanbul, Turkey</p>
    </div>
    <div class="footer-right">
      <p class="mono label">Authors</p>
      <ul>
        <li>Abd Alsalam Hijazi Kelani</li>
        <li>Ghaith Almadani</li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <span>© 2025 Biruni University. All rights reserved.</span>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding-top: 3rem;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: 3rem;
  }

  .footer-left { max-width: 420px; }

  .brand {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--cyan);
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .footer-left p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 0.35rem;
  }

  .uni { opacity: 0.6; font-size: 0.78rem !important; }

  .footer-right .label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 0.6rem;
  }

  .footer-right ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .footer-right li {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 1rem 0;
  }

  .footer-bottom span {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.5;
  }
</style>
