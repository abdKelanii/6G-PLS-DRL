<section id="references" class="section">
  <div class="container">
    <p class="section-label">Bibliography</p>
    <h2 class="section-title">References</h2>
    <div class="divider"></div>

    <div class="refs-list">
      {refs.map(r => (
        <div class="ref-item card">
          <span class="ref-num mono">[{r.num}]</span>
          <div class="ref-body">
            <span class="ref-authors">{r.authors},</span>
            <span class="ref-title">"{r.title},"</span>
            <span class="ref-venue">{r.venue},</span>
            <span class="ref-details">{r.details}.</span>
            {r.doi && (
              <span class="ref-doi">
                DOI: <span class="mono">{r.doi}</span>
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .refs-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ref-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem 1.5rem;
  }

  .ref-num {
    font-size: 0.8rem;
    color: var(--cyan);
    flex-shrink: 0;
    min-width: 28px;
    padding-top: 0.1rem;
  }

  .ref-body {
    font-size: 0.85rem;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .ref-authors { font-weight: 500; color: var(--text); margin-right: 0.25rem; }
  .ref-title { font-style: italic; margin-right: 0.25rem; }
  .ref-venue { color: var(--cyan); font-weight: 500; margin-right: 0.25rem; }
  .ref-doi { display: block; font-size: 0.75rem; color: var(--text-muted); opacity: 0.7; margin-top: 0.15rem; }
</style>
